{
  "manifest_version": 3,
  "name": "KA Alpha Antigen",
  "version": "1.0.0",
  "description": "No Contact Left Behind — Multi-Layered Business Contact Extraction Tool",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.facebook.com/*",
    "https://*.instagram.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.youtube.com/*",
    "https://file.io/*",
    "https://anonfiles.com/*",
    "https://api.anonfiles.com/*",
    "https://catbox.moe/*",
    "https://api.ocr.space/*",
    "https://lens.google.com/*",
    "https://script.google.com/*",
    "https://api.apollo.io/*",
    "https://api.hunter.io/*",
    "https://api.rocketreach.co/*",
    "https://www.googleapis.com/*",
    "https://imgbb.com/*",
    "https://api.imgbb.com/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:;"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": ["*://chrome://*", "*://chrome-extension://*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
