{
  "manifest_version": 3,
  "name": "KA Alpha Antigen",
  "version": "1.0.0",
  "description": "No Contact Left Behind — Multi-Layered Business Contact Extraction Tool",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.google.com/*",
    "https://*.googleapis.com/*",
    "https://docs.google.com/*",
    "https://sheets.googleapis.com/*",
    "https://script.google.com/*",
    "https://api.apollo.io/*",
    "https://api.hunter.io/*",
    "https://rocketreach.co/*",
    "https://catbox.moe/*",
    "https://api.ocr.space/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
